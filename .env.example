# Copy this file to .env and fill in your IQ Option credentials.
# .env is gitignored - never commit real credentials.
IQ_EMAIL=you@example.com
IQ_PASSWORD=your-password

# PRACTICE (default) or REAL. REAL only takes effect with IQ_ALLOW_REAL=1.
IQ_DEFAULT_BALANCE=PRACTICE

# Safety switch: trading tools refuse to act on the REAL balance unless this is 1.
IQ_ALLOW_REAL=0
